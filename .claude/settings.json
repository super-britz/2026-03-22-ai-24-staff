{
	"permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "MultiEdit",
      "Bash(bun *)",
      "Bash(npx *)",
      "Bash(git *)",
      "Bash(turbo *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(chmod *)",
      "Bash(jq *)",
      "Bash(date *)"
    ]
  },
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/hooks/post-edit-format.sh"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/hooks/pre-commit-quality.sh"
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/hooks/stop-workflow-continue.sh"
					}
				]
			}
		]
	}
}
