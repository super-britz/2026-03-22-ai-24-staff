{
	"permissions": {
		"allow": ["Read", "Edit", "Write", "MultiEdit", "Bash(*)"],
		"deny": [
			"Bash(rm -rf *)",
			"Bash(curl *)",
			"Bash(wget *)",
			"Bash(ssh *)",
			"Bash(scp *)"
		]
	},
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/hooks/post-edit-format.sh"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/hooks/pre-commit-quality.sh"
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/hooks/stop-workflow-continue.sh"
					}
				]
			}
		]
	}
}
